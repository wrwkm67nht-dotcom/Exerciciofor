/*Faça um programa que imprima a seguinte sequência:
100, 99, 98, . . . 1.*/
public class Exercicio1 {
    public static void main(String[] args) {
        int num;
        for(num=100; num>=1;num--){
            System.out.println(num+" ");
            
        }
    }
    
}
